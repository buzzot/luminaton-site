# --- Luminaton environment variables ---
# Copy this file to .env and fill in real values.
# On Hostinger: set these from hPanel → Node.js → Environment variables.

# Port that Hostinger / your host expects your Node app to listen on.
# Hostinger usually assigns this automatically — leave unset to default to 3000.
# PORT=3000

# Run mode. Set to "production" so session cookies use the Secure flag.
NODE_ENV=production

# Public URL of the site — used to build magic-link URLs in outgoing emails.
# Example: https://luminaton.com
APP_URL=https://luminaton.com

# SMTP credentials for sending email (contact form + customer-cabinet sign-in links).
# Recommended: use the Hostinger mailbox you create in hPanel → Emails.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@luminaton.com
SMTP_PASS=your-mailbox-password-here

# Where contact-form submissions are delivered.
MAIL_TO=sales@luminaton.com

# "From" header on outgoing email — should match a real mailbox on your domain.
MAIL_FROM=Luminaton <sales@luminaton.com>

# --- Customer cabinet inquiries / admin access ---
# Comma-separated email allowlist for admin access (inquiry panel, status changes).
# If not set, MAIL_TO is automatically admin. Add extra emails here to grant admin
# rights to more people without changing MAIL_TO.
# ADMIN_EMAILS=ceo@luminaton.com,ops@luminaton.com

# --- Instant per-event notifications ---
# Email MAIL_TO every time a customer signs in or downloads a datasheet.
# Set to "false" to silence individual events and rely on the daily/weekly summaries only.
INSTANT_NOTIFICATIONS=true

# --- Daily lead digest ---
# When to send the digest email summarizing yesterday's cabinet activity.
# Standard cron syntax: "minute hour day month weekday".
# Default = 08:00 every day. Leave commented out to keep the default.
# DIGEST_CRON=0 8 * * *

# IANA timezone the cron schedules below are evaluated in.
# Examples: "Europe/Warsaw", "Europe/London", "America/Los_Angeles", "Asia/Bangkok"
DIGEST_TIMEZONE=Europe/Warsaw

# --- Weekly leads.csv export ---
# When to email the full leads.csv as an attachment to MAIL_TO.
# Default = Monday at 08:00. Cron weekday field: 0/7=Sun, 1=Mon, ..., 6=Sat.
# WEEKLY_CSV_CRON=0 8 * * 1
