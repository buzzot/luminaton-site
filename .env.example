# --- Luminaton environment variables ---
# Copy this file to .env and fill in real values.
# On Hostinger: set these from hPanel → Node.js → Environment variables.

# Port that Hostinger / your host expects your Node app to listen on.
# Hostinger usually assigns this automatically — leave unset to default to 3000.
# PORT=3000

# Run mode. Set to "production" so session cookies use the Secure flag.
NODE_ENV=production

# Public URL of the site — used to build magic-link URLs in outgoing emails.
# Example: https://luminaton.com
APP_URL=https://luminaton.com

# SMTP credentials for sending email (contact form + customer-cabinet sign-in links).
# Recommended: use the Hostinger mailbox you create in hPanel → Emails.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@luminaton.com
SMTP_PASS=your-mailbox-password-here

# Where contact-form submissions are delivered.
MAIL_TO=sales@luminaton.com

# "From" header on outgoing email — should match a real mailbox on your domain.
MAIL_FROM=Luminaton <sales@luminaton.com>
